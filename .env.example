# Configuración de facturación electrónica ARCA/AFIP
# Copiar este archivo a .env y completar con tus datos reales
#
# IMPORTANTE: nunca subas el archivo .env a git.
# El .gitignore ya lo excluye.

# ── Obligatorio ──────────────────────────────────────────────────────────────

# CUIT del emisor (11 dígitos, sin guiones)
AFIP_CUIT=20123456789

# Certificado digital (.pem o .crt) emitido por AFIP/ARCA
# Para homologación y producción podés usar el mismo o uno diferente
AFIP_CERT_PATH=./certs/afip_cert.pem

# Clave privada RSA generada con generar_csr.py
AFIP_KEY_PATH=./certs/afip_key.pem

# Si usás certificados diferentes por entorno:
# AFIP_CERT_PATH_HOMO=./certs/afip_cert_homo.pem
# AFIP_KEY_PATH_HOMO=./certs/afip_key_homo.pem
# AFIP_CERT_PATH_PROD=./certs/afip_cert_prod.pem
# AFIP_KEY_PATH_PROD=./certs/afip_key_prod.pem

# Punto de venta registrado en AFIP (entero)
# En homologación usar 1 o el que tengas registrado en el ambiente de pruebas
AFIP_PUNTO_VENTA=1

# ── Opcional: datos del emisor para el PDF ────────────────────────────────────

AFIP_RAZON_SOCIAL=Juan Pérez
AFIP_DOMICILIO=Av. Corrientes 1234, CABA
# AFIP_NOMBRE_FANTASIA=
# AFIP_LOGO_PATH=./logo.png
# AFIP_INICIO_ACTIVIDADES=20200101
# AFIP_INGRESOS_BRUTOS=900-123456-7

# ── Opcional: límite para Consumidor Final ────────────────────────────────────
# Monto máximo para facturar sin identificar al receptor (AFIP actualiza este valor)
# AFIP_LIMITE_CF=97673.32

# ── Opcional: paths de caché (no modificar salvo necesidad) ──────────────────
# AFIP_TOKEN_CACHE_PATH=./.afip_token_cache
# AFIP_WSDL_CACHE_PATH=./.afip_wsdl_cache.db
