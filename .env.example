# ─────────────────────────────────────────────────────────────────────────────
# AFIP Facturación Electrónica — Configuración
# Copie este archivo como .env y complete los valores
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Identificación del emisor ──────────────────────────────────────────────────
# CUIT sin guiones ni espacios (11 dígitos)
AFIP_CUIT=20123456789

# ── Datos que aparecen en el encabezado del comprobante PDF ───────────────────
# Razón social (nombre legal ante AFIP)
AFIP_RAZON_SOCIAL=Juan Pérez

# Nombre de fantasía: si se configura, aparece prominente en el encabezado
# y la razón social se muestra como "de Juan Pérez"
AFIP_NOMBRE_FANTASIA=

# Domicilio comercial (Sector A del comprobante, campo obligatorio RG 1415)
AFIP_DOMICILIO=Av. Corrientes 1234, Ciudad Autónoma de Buenos Aires

# Domicilio fiscal si difiere del comercial (dejar vacío para usar el mismo)
AFIP_DOMICILIO_FISCAL=

# Fecha de inicio de actividades (formato DD/MM/AAAA)
AFIP_INICIO_ACTIVIDADES=01/01/2020

# Número de Ingresos Brutos o "EXENTO"
AFIP_INGRESOS_BRUTOS=EXENTO

# Ruta a imagen de logo en formato PNG (opcional)
# Ejemplo: ./logo.png  o  /ruta/absoluta/logo.png
AFIP_LOGO_PATH=

# ── Punto de venta ────────────────────────────────────────────────────────────
# Debe estar habilitado en el portal AFIP / ARCA
# En homologación se puede usar el número 1
AFIP_PUNTO_VENTA=1

# ── Límite Consumidor Final ───────────────────────────────────────────────────
# Monto máximo (en pesos) para emitir sin identificar al receptor
# Actualizar según RG vigente: https://www.afip.gob.ar
AFIP_LIMITE_CF=97673.32

# ── Certificados WSAA ─────────────────────────────────────────────────────────
# Se obtienen registrando el servicio wsfe en el portal AFIP / ARCA
# Ver instrucciones completas en README.md → "Obtener certificados AFIP"
#
# Opción A — certificados separados por entorno (recomendado):
AFIP_CERT_PATH_HOMO=./certs/homo/afip_20123456789.crt
AFIP_KEY_PATH_HOMO=./certs/homo/afip_20123456789.key
AFIP_CERT_PATH_PROD=./certs/afip_20123456789.crt
AFIP_KEY_PATH_PROD=./certs/afip_20123456789.key
#
# Opción B — mismo certificado para ambos entornos (más simple):
# AFIP_CERT_PATH=./certs/afip_20123456789.crt
# AFIP_KEY_PATH=./certs/afip_20123456789.key

# ── Caché (se genera automáticamente, no es necesario modificar) ─────────────
# AFIP_TOKEN_CACHE_PATH es un PREFIJO: el código agrega _{env}.json automáticamente
# para mantener caches separados entre homologación y producción.
# Ejemplo: ./.afip_token_cache → .afip_token_cache_homo.json / _prod.json
AFIP_TOKEN_CACHE_PATH=./.afip_token_cache
AFIP_WSDL_CACHE_PATH=./.afip_wsdl_cache.db
