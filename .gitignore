# Configuración local (contiene CUIT, paths de certificados)
.env

# Certificados y claves criptográficas — NUNCA subir
*.pem
*.key
*.crt
*.cer
*.pfx
*.p12
*.csr
certs/*
!certs/.gitkeep

# Caché de tokens WSAA y WSDL (se regeneran automáticamente)
.afip_token_cache*.json
.afip_wsdl_cache.db

# PDFs generados
factura_*.pdf
*.pdf

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Entornos virtuales
.venv/
venv/
env/
ENV/

# IDEs y editores
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Logs
*.log
